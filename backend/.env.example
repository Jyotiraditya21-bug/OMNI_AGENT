# Supabase Project URL (from your Supabase Dashboard API Settings)
SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key (from your Supabase Dashboard API Settings)
SUPABASE_KEY=your-supabase-anon-key

# Google OAuth 2.0 Client ID (for Google Login/API verification)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Google OAuth 2.0 Client Secret (for Google API operations)
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Symmetric encryption key generated using cryptography.fernet.Fernet.generate_key().decode()
# Used for encrypting/decrypting user API keys
ENCRYPTION_SECRET=your-32-byte-base64-fernet-key

# Base URL for the FastAPI backend
BACKEND_URL=http://localhost:8000

# Base URL for the React frontend
FRONTEND_URL=http://localhost:5173
