# Google OAuth 2.0 Client ID (for Google Login/API verification)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Google OAuth 2.0 Client Secret (for Google API operations)
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Symmetric encryption key generated using cryptography.fernet.Fernet.generate_key().decode()
# Used for encrypting/decrypting user API keys locally
ENCRYPTION_SECRET=your-32-byte-base64-fernet-key

# JWT secret key for signing session tokens
JWT_SECRET=your-random-jwt-secret-string

# Base URL for the FastAPI backend
BACKEND_URL=http://localhost:8000

# Base URL for the React frontend
FRONTEND_URL=http://localhost:5173

# Optional: Pre-populated developer sandbox keys
GROQ_API_KEY=your-groq-api-key
TAVILY_API_KEY=your-tavily-api-key
